#include <stdio.h>
#include <ctype.h>
#include <string.h>

char stack[100];
int top = -1;

void push(char x)
{
    stack[++top] = x;
}

char pop()
{
    return stack[top--];
}

int precedence(char op)
{
    if(op == '+' || op == '-')
        return 1;
    if(op == '*' || op == '/')
        return 2;
    if(op == '^')
        return 3;
    return 0;
}

int main()
{
    char infix[100] = "A+B*C-D";
    char postfix[100];

    int i=0, j=0;

    while(infix[i] != '\0')
    {
        if(isalnum(infix[i]))
        {
            postfix[j++] = infix[i];
        }

        else if(infix[i] == '(')
        {
            push(infix[i]);
        }

        else if(infix[i] == ')')
        {
            while(stack[top] != '(')
                postfix[j++] = pop();

            pop();
        }

        else
        {
            while(top!=-1 && precedence(stack[top]) >= precedence(infix[i]))
                postfix[j++] = pop();

            push(infix[i]);
        }

        i++;
    }

    while(top!=-1)
        postfix[j++] = pop();

    postfix[j] = '\0';

    printf("Postfix Expression: %s", postfix);

    return 0;
}

int recursiveBinary(int arr[], int low, int high, int key) {
    if(low > high)
        return -1;

    int mid = (low + high) / 2;

    if(arr[mid] == key)
        return mid;
    else if(arr[mid] < key)
        return recursiveBinary(arr, mid + 1, high, key);
    else
        return recursiveBinary(arr, low, mid - 1, key);
}

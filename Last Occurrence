int lastOccurrence(int arr[], int n, int key) {
    int low = 0, high = n - 1;
    int result = -1;

    while(low <= high) {
        int mid = (low + high) / 2;

        if(arr[mid] == key) {
            result = mid;
            low = mid + 1;   // move right
        }
        else if(arr[mid] < key)
            low = mid + 1;
        else
            high = mid - 1;
    }
    return result;
}

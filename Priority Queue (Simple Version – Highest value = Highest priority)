#include <stdio.h>
#define SIZE 5

int queue[SIZE];
int n = 0;

void enqueue(int value) {
    if (n == SIZE) {
        printf("Queue Full\n");
        return;
    }

    int i = n - 1;
    while (i >= 0 && queue[i] < value) {
        queue[i + 1] = queue[i];
        i--;
    }

    queue[i + 1] = value;
    n++;
}

void dequeue() {
    if (n == 0) {
        printf("Queue Empty\n");
        return;
    }

    printf("Deleted %d\n", queue[0]);

    for (int i = 0; i < n - 1; i++)
        queue[i] = queue[i + 1];

    n--;
}

void display() {
    for (int i = 0; i < n; i++)
        printf("%d ", queue[i]);
    printf("\n");
}

int main() {
    enqueue(10);
    enqueue(30);
    enqueue(20);
    display();
    dequeue();
    display();
}

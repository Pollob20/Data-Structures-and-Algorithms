#include <stdio.h>

int binarySearch(int arr[], int n, int key) {
    int low = 0, high = n - 1;
    int count = 0;

    while(low <= high) {
        count++;
        int mid = (low + high) / 2;

        if(arr[mid] == key) {
            printf("Found after %d steps\n", count);
            return mid;
        }
        else if(arr[mid] < key)
            low = mid + 1;
        else
            high = mid - 1;
    }

    printf("Not found. Steps = %d\n", count);
    return -1;
}

int main() {
    int arr[] = {10, 20, 30, 40, 50, 60, 70, 80};
    int n = 8;

    binarySearch(arr, n, 70);

    return 0;
}

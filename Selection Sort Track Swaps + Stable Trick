#include <stdio.h>

void stableSelectionSort(int arr[], int n) {
    int swaps = 0;

    for(int i = 0; i < n - 1; i++) {
        int min = i;

        for(int j = i + 1; j < n; j++)
            if(arr[j] < arr[min])
                min = j;

        int key = arr[min];

        while(min > i) {
            arr[min] = arr[min - 1];
            min--;
        }

        arr[i] = key;
        swaps++;
    }

    printf("Passes: %d\n", swaps);
}

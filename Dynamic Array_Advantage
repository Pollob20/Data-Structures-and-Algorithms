#include <stdio.h>
#include <stdlib.h>

int main() {
    int n = 3;

    int *arr = (int*) malloc(n * sizeof(int));

    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;

    n = 5;
    arr = realloc(arr, n * sizeof(int));

    arr[3] = 40;
    arr[4] = 50;

    for(int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }

    free(arr);

    return 0;
}

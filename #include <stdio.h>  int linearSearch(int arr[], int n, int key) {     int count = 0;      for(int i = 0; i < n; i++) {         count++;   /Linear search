#include <stdio.h>

int linearSearch(int arr[], int n, int key) {
    int count = 0;

    for(int i = 0; i < n; i++) {
        count++;   // comparison count
        if(arr[i] == key) {
            printf("Found after %d comparisons\n", count);
            return i;
        }
    }

    printf("Not found. Total comparisons = %d\n", count);
    return -1;
}

int main() {
    int arr[] = {10, 20, 30, 40, 50};
    int n = 5;

    linearSearch(arr, n, 50);

    return 0;
}

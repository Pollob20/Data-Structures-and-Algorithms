#include <stdio.h>

struct Student {
    int id;
    char name[20];
    float cgpa;
};

int main() {
    struct Student s1;

    s1.id = 101;
    strcpy(s1.name, "Pollob"); // string assign
    s1.cgpa = 3.85;

    printf("ID: %d\n", s1.id);
    printf("Name: %s\n", s1.name);
    printf("CGPA: %.2f\n", s1.cgpa);

    return 0;
}

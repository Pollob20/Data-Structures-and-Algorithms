#include <stdio.h>

int main() {
    int arr[] = {4, 2, 12, 3, 8};
    int n = 5;

    int minD[100], maxD[100];
    int f1=0,r1=-1,f2=0,r2=-1;

    for(int i=0;i<n;i++){

        while(f1<=r1 && arr[minD[r1]]>=arr[i]) r1--;
        minD[++r1]=i;

        while(f2<=r2 && arr[maxD[r2]]<=arr[i]) r2--;
        maxD[++r2]=i;

        printf("Min: %d Max: %d\n",arr[minD[f1]],arr[maxD[f2]]);
    }
}

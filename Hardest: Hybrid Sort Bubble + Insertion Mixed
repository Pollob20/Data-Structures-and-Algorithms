#include <stdio.h>

void insertion(int arr[], int left, int right) {
    for(int i = left + 1; i <= right; i++) {
        int key = arr[i];
        int j = i - 1;

        while(j >= left && arr[j] > key) {
            arr[j + 1] = arr[j];
            j--;
        }
        arr[j + 1] = key;
    }
}

void hybridSort(int arr[], int n) {
    int threshold = 4;

    for(int i = 0; i < n; i += threshold) {
        int right = i + threshold - 1;
        if(right >= n)
            right = n - 1;

        insertion(arr, i, right);
    }

    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < n - i - 1; j++) {
            if(arr[j] > arr[j + 1]) {
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

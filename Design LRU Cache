#include <stdio.h>
#include <stdlib.h>

#define CAPACITY 3

struct Node {
    int key;
    struct Node* prev;
    struct Node* next;
};

struct Node* head = NULL;
struct Node* tail = NULL;
int size = 0;

void moveToFront(struct Node* node) {
    if (node == head) return;

    if (node == tail)
        tail = tail->prev;

    if (node->prev)
        node->prev->next = node->next;

    if (node->next)
        node->next->prev = node->prev;

    node->prev = NULL;
    node->next = head;
    head->prev = node;
    head = node;
}

void insert(int key) {
    struct Node* temp = malloc(sizeof(struct Node));
    temp->key = key;
    temp->prev = NULL;
    temp->next = head;

    if (head)
        head->prev = temp;
    head = temp;

    if (tail == NULL)
        tail = temp;

    if (++size > CAPACITY) {
        struct Node* del = tail;
        tail = tail->prev;
        tail->next = NULL;
        free(del);
        size--;
    }
}

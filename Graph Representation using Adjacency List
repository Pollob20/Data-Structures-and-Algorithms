#include <stdio.h>
#include <stdlib.h>

struct Node{
    int vertex;
    struct Node* next;
};

struct Node* adj[10];

void addEdge(int u,int v){

    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->vertex = v;
    newNode->next = adj[u];
    adj[u] = newNode;

}

void printGraph(int vertices){

    for(int i=0;i<vertices;i++){

        struct Node* temp = adj[i];

        printf("Vertex %d:",i);

        while(temp!=NULL){
            printf(" -> %d",temp->vertex);
            temp=temp->next;
        }

        printf("\n");
    }
}

int main(){

    int vertices=4;

    for(int i=0;i<vertices;i++)
        adj[i]=NULL;

    addEdge(0,1);
    addEdge(0,2);
    addEdge(1,3);

    printGraph(vertices);

}

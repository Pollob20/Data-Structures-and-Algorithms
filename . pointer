#include <stdio.h>

struct Student {
    int id;
    float cgpa;
};

int main() {

    struct Student s[3];   

  
    for(int i = 0; i < 3; i++) {
        printf("Enter ID and CGPA for student %d: ", i+1);
        scanf("%d %f", &s[i].id, &s[i].cgpa);
    }

    printf("\nStudent Information:\n");

  
    for(int i = 0; i < 3; i++) {
        printf("ID: %d, CGPA: %.2f\n", s[i].id, s[i].cgpa);
    }

    return 0;
}
